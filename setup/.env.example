# Jarvis OS — Voice-Server-Umgebung (optional, Defaults sind sinnvoll)
# VOICE_PORT=5690
# VOICE_MODELS_DIR=~/voice-models
# VOICE_WHISPER=small
# VOICE_DE=de_DE-thorsten-high.onnx
# VOICE_RU=ru_RU-irina-medium.onnx
# VOICE_PERSONAL=de_DE-personal.onnx     # eigene trainierte Stimme (ersetzt "de" automatisch)
# VOICE_DATASET=dataset-personal         # Name des Aufnahme-Datasets fuer das Stimm-Training

# FlowDictate (core/tools/flowdictate.py)
# OLLAMA_URL=http://localhost:11434
# FLOW_MODEL=qwen2.5:7b
# FLOW_WHISPER=small
